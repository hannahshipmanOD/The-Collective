#!/usr/bin/env bash
# superdojo-run — Universal batch workload orchestrator
# Usage: ./scripts/superdojo-run workloads/<name>.toml

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

log() { echo -e "${BLUE}[superdojo-run]${NC} $*"; }
ok()  { echo -e "${GREEN}[ok]${NC} $*"; }
warn(){ echo -e "${YELLOW}[warn]${NC} $*"; }
err() { echo -e "${RED}[err]${NC} $*" >&2; }

if [[ $# -lt 1 ]]; then
  err "Usage: $0 <workload.toml>"
  exit 1
fi

WORKLOAD_FILE="$1"

if [[ ! -f "$WORKLOAD_FILE" ]]; then
  err "Workload file not found: $WORKLOAD_FILE"
  exit 1
fi

log "Loading workload: $WORKLOAD_FILE"

# Parse TOML (simple key=value extraction)
parse_toml_value() {
  local file="$1"
  local key="$2"
  grep -E "^${key}\s*=" "$file" | head -1 | sed 's/.*= *"\?//; s/"\?$//; s/^ *//; s/ *$//'
}

WORKLOAD_NAME=$(parse_toml_value "$WORKLOAD_FILE" "name")
WORKLOAD_DESC=$(parse_toml_value "$WORKLOAD_FILE" "description")
SKILL=$(parse_toml_value "$WORKLOAD_FILE" "skill")
PROMPT=$(parse_toml_value "$WORKLOAD_FILE" "prompt")

log "Workload: $WORKLOAD_NAME"
log "Description: $WORKLOAD_DESC"

# Extract scripts array
SCRIPTS_LINE=$(grep -E '^scripts\s*=' "$WORKLOAD_FILE" | head -1 || true)
if [[ -n "$SCRIPTS_LINE" ]]; then
  # Parse array values like scripts = ["scripts/foo.py", "scripts/bar.py"]
  SCRIPTS=$(echo "$SCRIPTS_LINE" | grep -oE '"[^"]+"' | tr -d '"')
else
  SCRIPTS=""
fi

# Run data scripts
if [[ -n "$SCRIPTS" ]]; then
  log "Running data scripts..."
  while IFS= read -r script; do
    script_path="$REPO_DIR/$script"
    if [[ -f "$script_path" ]]; then
      log "  Running: $script"
      python3 "$script_path" && ok "  $script done" || warn "  $script failed (non-fatal)"
    else
      warn "  Script not found: $script_path"
    fi
  done <<< "$SCRIPTS"
fi

# Build claude prompt
SKILL_ARG=""
if [[ -n "$SKILL" ]]; then
  SKILL_ARG="--skill $SKILL"
fi

if [[ -n "$PROMPT" ]]; then
  log "Running Claude with skill: ${SKILL:-none}"
  log "Prompt: $PROMPT"
  echo ""
  # Run with claude CLI if available
  if command -v claude &>/dev/null; then
    if [[ -n "$SKILL" ]]; then
      claude -p "@${SKILL} ${PROMPT}"
    else
      claude -p "$PROMPT"
    fi
  else
    warn "claude CLI not found. Install Claude Code to run this workload."
    echo "Would run: claude -p \"@${SKILL} ${PROMPT}\""
  fi
fi

ok "Workload $WORKLOAD_NAME complete."
